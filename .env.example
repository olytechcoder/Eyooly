# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://eyooly_user:your_password@localhost:5432/eyooly_db?schema=public"

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-here"

# Your production URL (no trailing slash)
NEXTAUTH_URL="https://eyooly.com"

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
# IMPORTANT: This key must NEVER be exposed in frontend code
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# The "from" address for magic-link and notification emails
# Must be a verified domain in your Resend account
EMAIL_FROM="Eyooly <noreply@eyooly.com>"

# Admin email — this address gets admin role automatically on first login
ADMIN_EMAIL="admin@eyooly.com"

# ─── File Uploads (optional — local disk by default) ─────────────────────────
# Set UPLOAD_PROVIDER=local to store uploads in /public/uploads (default)
# Set UPLOAD_PROVIDER=s3 to use AWS S3 or any S3-compatible storage
UPLOAD_PROVIDER="local"

# Required only when UPLOAD_PROVIDER=s3:
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_REGION="eu-west-1"
# AWS_S3_BUCKET="eyooly-uploads"
# AWS_S3_ENDPOINT="https://s3.amazonaws.com"  # or custom endpoint for Cloudflare R2 etc.

# ─── App Config ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://eyooly.com"
NEXT_PUBLIC_APP_NAME="Eyooly"
