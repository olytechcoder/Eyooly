// Eyooly — Prisma Schema (MVP v0.1)
// Database: PostgreSQL
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth.js required tables ──────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  city          String?
  bio           String?
  role          UserRole  @default(USER)
  verified      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accountType   String?

  accounts      Account[]
  sessions      Session[]
  listings      Listing[]
  savedListings SavedListing[]
  reports       Report[]
}

enum UserRole {
  USER
  ADMIN
}

// ─── Categories ───────────────────────────────────────────────────────────────

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  nameEs   String
  nameEn   String
  nameFr   String
  slug     String    @unique
  icon     String?
  color    String?
  order    Int       @default(0)

  listings Listing[]
}

// ─── Listings ─────────────────────────────────────────────────────────────────

model Listing {
  id              Int           @id @default(autoincrement())
  slug            String        @unique
  title           String
  description     String?       @db.Text
  price           Decimal?      @db.Decimal(12, 2)
  currency        String        @default("XAF")
  city            String?
  address         String?
  listingType     ListingType   @default(PRODUCT)
  status          ListingStatus @default(PENDING)
  featured        Boolean       @default(false)
  views           Int           @default(0)
  imageUrl        String?

  // Seller info (no auth required for MVP)
  sellerName      String?
  sellerWhatsapp  String?       // e.g. "+240222123456"
  sellerEmail     String?

  categoryId      Int?
  userId          String?       // optional — linked if user is logged in

  category        Category?     @relation(fields: [categoryId], references: [id])
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  images          ListingImage[]
  savedBy         SavedListing[]
  reports         Report[]

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

enum ListingType {
  PRODUCT
  SERVICE
  CLASSIFIED
  FOOD
  DELIVERY
  RIDE
}

enum ListingStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── Listing Images ───────────────────────────────────────────────────────────

model ListingImage {
  id        Int     @id @default(autoincrement())
  listingId Int
  url       String
  fileKey   String?
  sortOrder Int     @default(0)

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ─── Saved Listings ───────────────────────────────────────────────────────────

model SavedListing {
  id        Int      @id @default(autoincrement())
  userId    String
  listingId Int
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

// ─── Unified Request model (delivery / ride / food) ───────────────────────────

model Request {
  id        Int           @id @default(autoincrement())
  type      RequestType
  name      String
  phone     String
  email     String?
  pickup    String
  dropoff   String?
  notes     String?       @db.Text
  status    RequestStatus @default(PENDING)
  adminNote String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

enum RequestType {
  DELIVERY
  RIDE
  FOOD
}

enum RequestStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─── Waitlist ─────────────────────────────────────────────────────────────────

model WaitlistLead {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}

// ─── Contact Messages ─────────────────────────────────────────────────────────

model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Admin Actions log ────────────────────────────────────────────────────────

model AdminAction {
  id         Int      @id @default(autoincrement())
  adminEmail String
  action     String   // e.g. "approve_listing", "reject_listing"
  targetId   String   // the id of the affected record
  targetType String   // e.g. "listing", "request"
  note       String?
  createdAt  DateTime @default(now())
}

// ─── Reports for listings ─────────────────────────────────────────────────────

model Report {
  id          String   @id @default(cuid())
  listingId   Int
  reporterId  String
  reason      String
  description String?
  status      String   @default("pending") // pending, reviewed, dismissed, resolved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing     Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([reporterId])
  @@index([status])
  @@index([createdAt])
}